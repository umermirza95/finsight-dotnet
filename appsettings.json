{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host={IP};Database={DB};Username={USER};Password=PASSWORD"
  },
  "Jwt": {
    "Key": "{JWT_KEY}",
    "Issuer": "{JWT_ISSUER}",
    "Audience": "{JWT_AUDIENCE}"
  },
  "ExchangeRateApi": {
    "BaseUrl": "{API_URL}",
    "ApiKey": "{YOUR_SECRET_TOKEN_HERE}"
  },
  "Api":{
    "BaseUrl": "{BASE_API_URL}"
  },
  "Gemini": {
    "ApiKey": "{GEMINI_API_KEY}"
  },
  "Alpaca": {
    "ApiKey": "{ALPACA_API_KEY}",
    "ApiSecret": "{ALPACA_API_SECRET}",
    "BaseUrl": "https://data.alpaca.markets"
  },
  "IBKR": {
    "Host": "127.0.0.1",
    "Port": 7497,
    "ClientId": 1
  },
  "Slack": {
    "WebhookUrl": "{SLACK_WEBHOOK_URL}"
  }
}
